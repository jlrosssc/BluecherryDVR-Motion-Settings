addJs(<<<'JS'
$(function() {
    /* Recommend Motion Sensitivity background job: start */
    function recommendMotionApplyToGrid(map) {
        var cells = $(".grid-bl .table-grid td");
        var classes = ["bg-default", "bg-success", "bg-info", "bg-primary", "bg-warning", "bg-danger"];
        if (!map || cells.length !== map.length) {
            $("#auto-motion-status").removeClass("text-muted text-success").addClass("text-danger").text("Recommended map does not match this camera grid.");
            return false;
        }
        cells.each(function(i) {
            var level = parseInt(map.charAt(i), 10);
            var cls = classes[level] || classes[0];
            $(this).removeClass(classes.join(" ")).addClass(cls).attr("data-type", level);
        });
        $("#motion-map").val(map);
        return true;
    }

    function recommendMotionCountsText(counts) {
        var labels = {"0": "off", "1": "minimal", "2": "low", "3": "average", "4": "high", "5": "very high"};
        var parts = [];
        $.each(labels, function(level, label) {
            if (counts && counts[level] !== undefined) parts.push(label + ": " + counts[level]);
        });
        return parts.join(", ");
    }

    function recommendMotionProgressText(progress) {
        if (!progress) return "Recommendation scan is still running...";
        var phase = progress.phase || progress.state || "";
        var current = parseInt(progress.current, 10);
        var total = parseInt(progress.total, 10);
        var found = parseInt(progress.candidate_count, 10);
        var hasTotal = !isNaN(total) && total > 0;
        var hasCurrent = !isNaN(current);
        var hasFound = !isNaN(found);
        var text = progress.message || "Recommendation scan is still running.";

        if (phase === "finding") {
            text = "Finding recordings for this camera...";
        } else if (phase === "copying") {
            if (hasFound && hasTotal && hasCurrent) {
                text = "Found " + found + " recordings in the selected window. Copying sample " + current + " of " + total + ".";
            } else if (hasFound && hasTotal) {
                text = "Found " + found + " recordings in the selected window. Preparing " + total + " samples.";
            } else if (hasTotal && hasCurrent) {
                text = "Copying sample " + current + " of " + total + ".";
            }
        } else if (phase === "analyzing" && hasTotal && hasCurrent) {
            text = "Analyzing sample " + current + " of " + total + ".";
        } else if (phase === "optimizing" && hasTotal && hasCurrent) {
            text = "Optimized Scan reviewed " + current + " of up to " + total + " samples.";
            if (progress.change_percent !== undefined) {
                text += " Map changed " + progress.change_percent + "% in the latest batch.";
            } else if (progress.frame_count !== undefined) {
                text += " Checking whether more samples are still useful.";
            }
        } else if (phase === "mapping") {
            text = progress.message || "Building recommended motion map.";
        } else if (phase === "complete") {
            text = "Recommendation complete.";
        }

        if (progress.updated_at) {
            text += " Updated " + progress.updated_at + ".";
        }
        return text;
    }

    function recommendMotionStorageKey() {
        var id = $("#motion-submit").find("input[name=id]").val() || "unknown";
        return "bluecherryRecommendMotionJob:" + id;
    }

    function recommendMotionStopButton() {
        var button = $("#auto-motion-stop");
        if (!button.length) {
            button = $('<button type="button" class="btn btn-default" id="auto-motion-stop" style="margin-left:6px; display:none;"><i class="fa fa-stop fa-fw"></i> Stop</button>');
            $("#auto-motion-detect").after(button);
        }
        return button;
    }

    function recommendMotionSetRunning(running) {
        recommendMotionStopButton().toggle(!!running);
    }

    function recommendMotionCancel(jobId) {
        var status = $("#auto-motion-status");
        status.removeClass("text-danger text-success").addClass("text-muted").text("Stopping recommendation scan...");
        $.ajax({
            type: "POST",
            url: "/ajax/automotionmap.php",
            dataType: "json",
            data: {action: "cancel", job_id: jobId}
        }).done(function(msg) {
            localStorage.removeItem(recommendMotionStorageKey());
            recommendMotionSetRunning(false);
            if (parseInt(msg.status, 10) === 6) {
                status.removeClass("text-muted text-danger").addClass("text-success").text((msg && msg.msg) ? msg.msg : "Recommendation scan canceled.");
            } else {
                status.removeClass("text-muted text-success").addClass("text-danger").text((msg && msg.msg) ? msg.msg : "Could not stop recommendation scan.");
            }
        }).fail(function(xhr) {
            var message = "Could not stop recommendation scan.";
            if (xhr && xhr.responseText) message += " " + xhr.responseText.substring(0, 180);
            status.removeClass("text-muted text-success").addClass("text-danger").text(message);
        });
    }

    function recommendMotionPoll(jobId) {
        var status = $("#auto-motion-status");
        recommendMotionSetRunning(true);
        $.ajax({
            type: "POST",
            url: "/ajax/automotionmap.php",
            dataType: "json",
            data: {action: "status", job_id: jobId}
        }).done(function(msg) {
            if (parseInt(msg.status, 10) === 6 && msg.data && msg.data.state === "complete") {
                localStorage.removeItem(recommendMotionStorageKey());
                recommendMotionSetRunning(false);
                if (recommendMotionApplyToGrid(msg.data.motion_map)) {
                    status.removeClass("text-muted text-danger").addClass("text-success")
                        .text("Loaded recommendation. Review/edit the grid, then click Save Changes. Proposed: " + recommendMotionCountsText(msg.data.proposed_counts));
                    if ($.notify) $.notify({icon: "fa fa-check fa-fw", message: msg.msg}, {type: "success", delay: 6000});
                }
            } else if (parseInt(msg.status, 10) === 6 && msg.data && msg.data.state === "running") {
                status.removeClass("text-danger text-success").addClass("text-muted").text(recommendMotionProgressText(msg.data.progress));
                setTimeout(function() { recommendMotionPoll(jobId); }, 5000);
            } else if (parseInt(msg.status, 10) === 6 && msg.data && msg.data.state === "canceled") {
                localStorage.removeItem(recommendMotionStorageKey());
                recommendMotionSetRunning(false);
                status.removeClass("text-muted text-danger").addClass("text-success").text("Recommendation scan canceled.");
            } else {
                localStorage.removeItem(recommendMotionStorageKey());
                recommendMotionSetRunning(false);
                status.removeClass("text-muted text-success").addClass("text-danger").text((msg && msg.msg) ? msg.msg : "Recommendation scan failed.");
                if ($.notify) $.notify({icon: "fa fa-times-circle fa-fw", message: (msg && msg.msg) ? msg.msg : "Recommendation scan failed."}, {type: "danger", delay: 8000});
            }
        }).fail(function() {
            status.removeClass("text-success").addClass("text-muted").text("Waiting to reconnect to recommendation scan...");
            setTimeout(function() { recommendMotionPoll(jobId); }, 10000);
        });
    }

    $("#auto-motion-detect").off("click.recommendMotion").on("click.recommendMotion", function(e) {
        e.preventDefault();
        e.stopPropagation();
        var button = $(this);
        var status = $("#auto-motion-status");
        var id = $("#motion-submit").find("input[name=id]").val();
        var mode = $("#auto-motion-scan-mode").val();
        var deepHours = parseInt($("#auto-motion-deep-hours").val(), 10) || 24;
        var scanSamples = 2;
        button.button("loading");
        if (mode === "deep" || mode === "optimized") {
            deepHours = Math.max(24, Math.min(168, deepHours));
            $("#auto-motion-deep-hours").val(deepHours);
            if (mode === "deep") {
                var samplesPerHour = parseInt($("#auto-motion-samples-per-hour").val(), 10) || 4;
                samplesPerHour = Math.max(1, Math.min(8, samplesPerHour));
                $("#auto-motion-samples-per-hour").val(samplesPerHour);
                scanSamples = deepHours * samplesPerHour;
                if (!confirm("Deep Scan will start a background job across " + deepHours + " hours at " + samplesPerHour + " samples per hour, up to " + scanSamples + " recordings. This may take several minutes. Continue?")) {
                    button.button("reset");
                    return false;
                }
                status.removeClass("text-danger text-success").addClass("text-muted").text("Starting Deep Scan background job for up to " + scanSamples + " recordings...");
            } else {
                scanSamples = deepHours * 4;
                if (!confirm("Optimized Scan will automatically sample recordings across " + deepHours + " hours and stop when the recommendation stabilizes. It may use up to " + scanSamples + " recordings. Continue?")) {
                    button.button("reset");
                    return false;
                }
                status.removeClass("text-danger text-success").addClass("text-muted").text("Starting Optimized Scan background job...");
            }
        } else {
            status.removeClass("text-danger text-success").addClass("text-muted").text("Starting Quick Scan background job...");
        }
        $.ajax({
            type: "POST",
            url: "/ajax/automotionmap.php",
            dataType: "json",
            data: {
                action: "start",
                id: id,
                sensitivity: $("#auto-motion-sensitivity").val(),
                noise_suppression: $("#auto-motion-noise").val(),
                scan_mode: mode,
                deep_hours: deepHours,
                samples_per_hour: (mode === "deep" ? samplesPerHour : 0),
                samples: scanSamples,
                frames_per_video: (mode === "deep" ? 3 : 2)
            }
        }).done(function(msg) {
            if (parseInt(msg.status, 10) === 6 && msg.data && msg.data.job_id) {
                localStorage.setItem(recommendMotionStorageKey(), msg.data.job_id);
                recommendMotionSetRunning(true);
                status.removeClass("text-danger text-success").addClass("text-muted").text("Recommendation scan started. Waiting for results...");
                recommendMotionPoll(msg.data.job_id);
            } else {
                status.removeClass("text-muted text-success").addClass("text-danger").text((msg && msg.msg) ? msg.msg : "Could not start recommendation scan.");
            }
        }).fail(function(xhr) {
            var message = "Could not start recommendation scan.";
            if (xhr && xhr.responseText) message += " " + xhr.responseText.substring(0, 180);
            status.removeClass("text-muted text-success").addClass("text-danger").text(message);
        }).always(function() {
            button.button("reset");
        });
    });

    recommendMotionStopButton().off("click.recommendMotionStop").on("click.recommendMotionStop", function(e) {
        e.preventDefault();
        e.stopPropagation();
        var jobId = localStorage.getItem(recommendMotionStorageKey());
        if (!jobId) {
            recommendMotionSetRunning(false);
            $("#auto-motion-status").removeClass("text-muted text-success").addClass("text-danger").text("No recommendation scan is running for this camera.");
            return false;
        }
        if (confirm("Stop the current recommendation scan for this camera?")) {
            recommendMotionCancel(jobId);
        }
        return false;
    });

    $("#auto-motion-scan-mode").off("change.recommendMotionMode").on("change.recommendMotionMode", function() {
        var mode = $(this).val();
        var deep = mode === "deep";
        var windowed = deep || mode === "optimized";
        $("#auto-motion-deep-hours").prop("disabled", !windowed);
        $("#auto-motion-samples-per-hour").prop("disabled", !deep);
        $(".auto-motion-deep-option").toggle(deep);
        $("#auto-motion-status").removeClass("text-danger text-success").addClass("text-muted")
            .text(mode === "optimized" ? "Optimized Scan samples until the recommendation stabilizes. Review/edit, then click Save Changes." : (deep ? "Deep Scan samples recordings across the selected hours. Review/edit, then click Save Changes." : "Quick Scan uses recent recordings. Review/edit, then click Save Changes."));
    }).trigger("change.recommendMotionMode");

    var previousJob = localStorage.getItem(recommendMotionStorageKey());
    if (previousJob) {
        recommendMotionSetRunning(true);
        $("#auto-motion-status").removeClass("text-danger text-success").addClass("text-muted").text("Checking previous recommendation scan...");
        recommendMotionPoll(previousJob);
    } else {
        recommendMotionSetRunning(false);
    }
    /* Recommend Motion Sensitivity background job: end */
});
JS
);
