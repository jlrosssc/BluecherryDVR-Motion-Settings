#!/usr/bin/env python3
"""Bluecherry motion map optimizer.

Builds a proposed Bluecherry Devices.motion_map from recent camera recordings.
The default mode is dry-run: it writes a report and preview, but does not
modify the database unless --apply is supplied.
"""

import argparse
import collections
import datetime as dt
import json
import math
import os
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


CONFIG_PATH = "/etc/bluecherry.conf"
RECORDINGS_ROOT = "/var/lib/bluecherry/recordings"
FFMPEG = "/usr/lib/bluecherry/ffmpeg"
DEFAULT_WORK_DIR = str(Path.home() / "bluecherry-motion-optimizer")
VIDEO_EXTENSIONS = (".mkv", ".mp4", ".avi", ".mov")


COLORS = {
    "0": "#555555",
    "1": "#55a868",
    "2": "#4c9ed9",
    "3": "#4f6bdc",
    "4": "#d99a2b",
    "5": "#d9534f",
}

LABELS = {
    "0": "off",
    "1": "minimal",
    "2": "low",
    "3": "average",
    "4": "high",
    "5": "very high",
}


def friendly_now():
    return dt.datetime.now().astimezone().strftime("%b %-d, %Y %-I:%M:%S %p %Z")


def run(cmd, check=True, capture=True, env=None):
    kwargs = {
        "universal_newlines": True,
        "stdout": subprocess.PIPE if capture else None,
        "stderr": subprocess.PIPE if capture else None,
    }
    if env is not None:
        kwargs["env"] = env
    proc = subprocess.run(cmd, **kwargs)
    if check and proc.returncode != 0:
        stderr = proc.stderr.strip() if proc.stderr else ""
        raise RuntimeError("Command failed: {}\n{}".format(" ".join(cmd), stderr))
    return proc


def read_bluecherry_config(path=CONFIG_PATH):
    cfg = {}
    with open(path) as fh:
        for raw in fh:
            line = raw.strip().rstrip(";")
            if "=" not in line:
                continue
            key, value = [part.strip() for part in line.split("=", 1)]
            if key in ("dbname", "user", "password", "host"):
                cfg[key] = value.strip('"')
    required = ("dbname", "user", "password")
    missing = [key for key in required if key not in cfg]
    if missing:
        raise RuntimeError("Missing Bluecherry DB config keys: {}".format(", ".join(missing)))
    cfg.setdefault("host", "127.0.0.1")
    return cfg


def mysql_cmd(cfg, sql):
    return [
        "mysql",
        "-N",
        "-B",
        "-h" + cfg["host"],
        "-u" + cfg["user"],
        "-p" + cfg["password"],
        cfg["dbname"],
        "-e",
        sql,
    ]


def query_rows(cfg, sql):
    proc = run(mysql_cmd(cfg, sql))
    rows = []
    for line in proc.stdout.splitlines():
        rows.append(line.split("\t"))
    return rows


def list_cameras(cfg):
    sql = (
        "SELECT id, device_name, protocol, IFNULL(driver,''), IFNULL(signal_type,''), "
        "LENGTH(motion_map), motion_algorithm, frame_downscale_factor, min_motion_area "
        "FROM Devices ORDER BY id"
    )
    return query_rows(cfg, sql)


def get_camera(cfg, camera_id):
    sql = (
        "SELECT id, device_name, protocol, IFNULL(driver,''), IFNULL(signal_type,''), "
        "motion_map, motion_algorithm, frame_downscale_factor, min_motion_area "
        "FROM Devices WHERE id={}".format(int(camera_id))
    )
    rows = query_rows(cfg, sql)
    if not rows:
        raise RuntimeError("No Bluecherry camera found with id {}".format(camera_id))
    row = rows[0]
    return {
        "id": int(row[0]),
        "name": row[1] or "Camera {}".format(row[0]),
        "protocol": row[2],
        "driver": row[3],
        "signal_type": row[4],
        "motion_map": row[5],
        "motion_algorithm": row[6],
        "frame_downscale_factor": row[7],
        "min_motion_area": row[8],
    }


def grid_size(camera):
    driver = (camera.get("driver") or "").lower()
    signal = (camera.get("signal_type") or "").lower()
    if driver == "tw5864":
        return 16, 12
    if driver in ("solo6110", "solo6010"):
        return (22, 18) if signal == "pal" else (22, 15)
    return 32, 24


def shell_quote_single(value):
    return "'" + value.replace("'", "'\"'\"'") + "'"


def recording_timestamp(path):
    parts = path.parts
    for index in range(len(parts) - 5):
        year, month, day, camera, filename = parts[index:index + 5]
        match = re.match(r"^(\d{2})-(\d{2})-(\d{2})", filename)
        if not match:
            continue
        if not (year.isdigit() and month.isdigit() and day.isdigit() and camera.isdigit()):
            continue
        try:
            return dt.datetime(
                int(year),
                int(month),
                int(day),
                int(match.group(1)),
                int(match.group(2)),
                int(match.group(3)),
            )
        except ValueError:
            return None
    return None


def choose_evenly_spaced(paths, count):
    paths = list(paths)
    if len(paths) <= count:
        return paths
    if count <= 1:
        return [paths[-1]]
    selected = []
    last_index = len(paths) - 1
    for i in range(count):
        index = int(round(i * last_index / float(count - 1)))
        selected.append(paths[index])
    return selected


def select_recordings(paths, sample_count, lookback_hours=None):
    now = dt.datetime.now()
    stamped = []
    for path in paths:
        timestamp = recording_timestamp(path)
        if timestamp is None:
            try:
                timestamp = dt.datetime.fromtimestamp(path.stat().st_mtime)
            except FileNotFoundError:
                continue
        stamped.append((timestamp, path))
    stamped.sort(key=lambda item: item[0])

    if lookback_hours:
        cutoff = now - dt.timedelta(hours=int(lookback_hours))
        window = [(timestamp, path) for timestamp, path in stamped if timestamp >= cutoff]
        if window:
            stamped = window
        return [path for _timestamp, path in choose_evenly_spaced(stamped, int(sample_count))]

    return [path for _timestamp, path in stamped[-int(sample_count):]]


def copy_recent_recordings(camera_id, sample_dir, sample_count, lookback_hours=None):
    sample_dir.mkdir(parents=True, exist_ok=True)
    for old in sample_dir.glob("*"):
        if old.is_file():
            old.unlink()

    camera_dir = "{:06d}".format(int(camera_id))
    direct_files = []
    root = Path(RECORDINGS_ROOT)
    if root.exists() and os.access(str(root), os.R_OK):
        try:
            for path in root.rglob("*"):
                if not path.is_file():
                    continue
                if path.suffix.lower() not in VIDEO_EXTENSIONS:
                    continue
                parts = path.parts
                if camera_dir in parts:
                    direct_files.append(path)
        except OSError:
            direct_files = []

    if direct_files:
        selected_files = select_recordings(direct_files, sample_count, lookback_hours)
        copied = []
        for index, source in enumerate(selected_files, 1):
            target = sample_dir / "sample_{}{}".format(index, source.suffix.lower())
            try:
                shutil.copy2(str(source), str(target))
            except (FileNotFoundError, OSError):
                continue
            try:
                os.chmod(str(target), 0o644)
            except OSError:
                pass
            copied.append(target)
        if not copied:
            raise RuntimeError("Selected recordings disappeared before analysis could copy them")
        return sorted(path for path in sample_dir.iterdir() if path.is_file())

    if shutil.which("docker") is None:
        raise RuntimeError("Recordings are not directly readable and docker is not available")

    if lookback_hours:
        script_filter = "awk -v cutoff=$(date -d '-{hours} hours' +%s) '{{ cmd=\"stat -c %Y \\\"\"$0\"\\\"\"; cmd | getline m; close(cmd); if (m >= cutoff) print $0; }}' | ".format(hours=int(lookback_hours))
        script_select = "awk -v n={count} '{{ a[++c]=$0 }} END {{ if (c <= n) {{ for (i=1; i<=c; i++) print a[i]; }} else {{ for (i=1; i<=n; i++) {{ idx=int((i-1)*(c-1)/(n-1)+1.5); print a[idx]; }} }} }}' | ".format(count=int(sample_count))
    else:
        script_filter = ""
        script_select = "tail -n {count} | ".format(count=int(sample_count))

    script = (
        "set -eu; "
        "i=0; "
        "find /recordings -type f -path '*/{camera}/*' | grep -Ei '\\.(mkv|mp4|avi|mov)$' | sort | "
        "{script_filter}"
        "{script_select}"
        "while IFS= read -r f; do i=$((i+1)); ext=\"${{f##*.}}\"; cp \"$f\" \"/work/sample_${{i}}.${{ext}}\"; done; "
        "chmod 0644 /work/* 2>/dev/null || true"
    ).format(camera=camera_dir, script_filter=script_filter, script_select=script_select)

    cmd = [
        "docker",
        "run",
        "--rm",
        "-v",
        "{}:/recordings:ro".format(RECORDINGS_ROOT),
        "-v",
        "{}:/work".format(str(sample_dir)),
        "alpine:latest",
        "sh",
        "-c",
        script,
    ]
    run(cmd, capture=True)
    files = sorted(path for path in sample_dir.iterdir() if path.is_file())
    if not files:
        raise RuntimeError("No recent recordings copied for camera {}".format(camera_id))
    return files


def extract_gray_frames(video_files, frame_dir, frames_per_video, width, height):
    frame_dir.mkdir(parents=True, exist_ok=True)
    extracted = []
    for index, video in enumerate(video_files, 1):
        if not video.exists():
            continue
        raw_output = frame_dir / "video{:02d}.gray".format(index)
        cmd = [
            FFMPEG,
            "-hide_banner",
            "-loglevel",
            "error",
            "-y",
            "-i",
            str(video),
            "-vf",
            "fps=1,scale={}:{},format=gray".format(width, height),
            "-frames:v",
            str(int(frames_per_video)),
            "-f",
            "rawvideo",
            str(raw_output),
        ]
        env = os.environ.copy()
        env["LD_LIBRARY_PATH"] = "/usr/lib/bluecherry:" + env.get("LD_LIBRARY_PATH", "")
        proc = run(cmd, check=False, env=env)
        if proc.returncode != 0:
            continue
        frame_size = width * height
        data = raw_output.read_bytes() if raw_output.exists() else b""
        for frame_index, start in enumerate(range(0, len(data), frame_size), 1):
            chunk = data[start:start + frame_size]
            if len(chunk) != frame_size:
                continue
            frame_path = frame_dir / "video{:02d}_{:03d}.gray".format(index, frame_index)
            frame_path.write_bytes(chunk)
            extracted.append(frame_path)
    if len(extracted) < 2:
        raise RuntimeError("Could not extract enough frames for analysis")
    return extracted


def frame_cell_means(path, cols, rows, width, height):
    data = path.read_bytes()
    if len(data) != width * height:
        raise RuntimeError("{} has unexpected raw frame size".format(path))
    sums = [0.0] * (cols * rows)
    counts = [0] * (cols * rows)
    for y in range(height):
        row = min(rows - 1, int(y * rows / height))
        for x in range(width):
            col = min(cols - 1, int(x * cols / width))
            gray = data[y * width + x]
            cell = row * cols + col
            sums[cell] += gray
            counts[cell] += 1
    return [sums[i] / counts[i] if counts[i] else 0.0 for i in range(cols * rows)]


def percentile(values, pct):
    if not values:
        return 0.0
    ordered = sorted(values)
    pos = (len(ordered) - 1) * pct
    low = int(math.floor(pos))
    high = int(math.ceil(pos))
    if low == high:
        return ordered[low]
    return ordered[low] * (high - pos) + ordered[high] * (pos - low)


def parse_zones(values):
    zones = []
    for value in values or []:
        parts = [int(part) for part in value.split(",")]
        if len(parts) != 4:
            raise RuntimeError("Zone must be x1,y1,x2,y2: {}".format(value))
        zones.append(tuple(parts))
    return zones


def in_zone(index, cols, zones):
    row = index // cols
    col = index % cols
    for x1, y1, x2, y2 in zones:
        if x1 <= col <= x2 and y1 <= row <= y2:
            return True
    return False


def build_map(frame_paths, cols, rows, frame_width, frame_height, sensitivity, noise_suppression, keep_zones, exclude_zones):
    means = [frame_cell_means(path, cols, rows, frame_width, frame_height) for path in frame_paths]
    cell_count = cols * rows
    motion = [0.0] * cell_count
    active_counts = [0] * cell_count
    transitions = max(1, len(means) - 1)

    for prev, current in zip(means, means[1:]):
        diffs = [abs(current[i] - prev[i]) for i in range(cell_count)]
        threshold = max(3.0, percentile(diffs, 0.60))
        for i, diff in enumerate(diffs):
            motion[i] += diff
            if diff >= threshold:
                active_counts[i] += 1

    scores = [value / transitions for value in motion]
    p50 = max(0.01, percentile(scores, 0.50))
    p75 = max(p50 + 0.01, percentile(scores, 0.75))
    p90 = max(p75 + 0.01, percentile(scores, 0.90))
    p97 = max(p90 + 0.01, percentile(scores, 0.97))

    sens_shift = (int(sensitivity) - 5) * 0.08
    thresholds = [
        p50 * (1.20 - sens_shift),
        p75 * (1.08 - sens_shift),
        p90 * (1.00 - sens_shift),
        p97 * (0.92 - sens_shift),
    ]

    output = []
    for i, score in enumerate(scores):
        active_ratio = active_counts[i] / float(transitions)
        if score < thresholds[0]:
            level = 0
        elif score < thresholds[1]:
            level = 1
        elif score < thresholds[2]:
            level = 2
        elif score < thresholds[3]:
            level = 3
        else:
            level = 4

        if sensitivity >= 8 and level > 0:
            level = min(5, level + 1)
        if sensitivity <= 3 and level > 0:
            level = max(1, level - 1)

        if noise_suppression and active_ratio > 0.70 and level >= 3:
            reduction = 1 + int(noise_suppression >= 7)
            level = max(1, level - reduction)

        if in_zone(i, cols, exclude_zones):
            level = 0
        if in_zone(i, cols, keep_zones):
            level = max(level, 3)

        output.append(str(level))

    return "".join(output), {
        "scores": scores,
        "active_counts": active_counts,
        "transitions": transitions,
        "thresholds": thresholds,
        "p50": p50,
        "p75": p75,
        "p90": p90,
        "p97": p97,
    }


def write_svg(path, motion_map, cols, rows, title):
    cell = 24
    legend_h = 74
    width = cols * cell
    height = rows * cell + legend_h
    parts = [
        '<svg xmlns="http://www.w3.org/2000/svg" width="{0}" height="{1}" viewBox="0 0 {0} {1}">'.format(width, height),
        '<rect width="100%" height="100%" fill="#171717"/>',
        '<text x="8" y="22" fill="#f4f4f4" font-family="Arial" font-size="16">{}</text>'.format(escape_xml(title)),
    ]
    yoff = 36
    for index, level in enumerate(motion_map):
        row = index // cols
        col = index % cols
        parts.append(
            '<rect x="{x}" y="{y}" width="{cell}" height="{cell}" fill="{color}" fill-opacity="0.82" stroke="#111" stroke-width="1"/>'.format(
                x=col * cell,
                y=yoff + row * cell,
                cell=cell,
                color=COLORS.get(level, "#555555"),
            )
        )
    legend_y = yoff + rows * cell + 24
    x = 8
    for level in ("0", "1", "2", "3", "4", "5"):
        parts.append('<rect x="{x}" y="{y}" width="16" height="16" fill="{color}"/>'.format(x=x, y=legend_y - 13, color=COLORS[level]))
        parts.append('<text x="{x}" y="{y}" fill="#eee" font-family="Arial" font-size="12">{label}</text>'.format(x=x + 22, y=legend_y, label=LABELS[level]))
        x += 105
    parts.append("</svg>")
    path.write_text("\n".join(parts) + "\n")


def escape_xml(value):
    return str(value).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;").replace('"', "&quot;")


def write_report(path, payload):
    lines = [
        "Bluecherry Motion Map Optimizer",
        "Generated: {}".format(payload["generated_at"]),
        "Camera: {} ({})".format(payload["camera_name"], payload["camera_id"]),
        "Grid: {} x {}".format(payload["cols"], payload["rows"]),
        "Sensitivity: {}".format(payload["sensitivity"]),
        "Noise suppression: {}".format(payload["noise_suppression"]),
        "Applied to database: {}".format("yes" if payload["applied"] else "no"),
        "",
        "Current map counts: {}".format(payload["current_counts"]),
        "Proposed map counts: {}".format(payload["proposed_counts"]),
        "",
        "Preview SVG: {}".format(payload["preview_svg"]),
        "JSON report: {}".format(payload["json_report"]),
    ]
    if payload.get("backup_file"):
        lines.append("Rollback file: {}".format(payload["backup_file"]))
    path.write_text("\n".join(lines) + "\n")


def counts_for_map(motion_map):
    return dict(sorted(collections.Counter(motion_map).items()))


def apply_map(cfg, camera, motion_map, work_dir):
    if not re.match(r"^[0-5]+$", motion_map):
        raise RuntimeError("Refusing to save invalid motion map")
    backup_dir = work_dir / "backups"
    backup_dir.mkdir(parents=True, exist_ok=True)
    stamp = dt.datetime.now().astimezone().strftime("%Y%m%d-%H%M%S-%Z")
    backup_file = backup_dir / "camera-{}-motion-map-{}.json".format(camera["id"], stamp)
    backup_file.write_text(json.dumps({
        "generated_at": friendly_now(),
        "camera_id": camera["id"],
        "camera_name": camera["name"],
        "previous_motion_map": camera["motion_map"],
        "new_motion_map": motion_map,
    }, indent=2, sort_keys=True) + "\n")
    sql = "UPDATE Devices SET motion_map='{}' WHERE id={}".format(motion_map, int(camera["id"]))
    run(mysql_cmd(cfg, sql))
    return str(backup_file)


def cmd_list(args):
    cfg = read_bluecherry_config(args.config)
    rows = list_cameras(cfg)
    print("ID\tName\tProtocol\tDriver\tSignal\tMapLen\tAlgorithm\tDownscale\tMinArea")
    for row in rows:
        print("\t".join(row))


def cmd_analyze(args):
    cfg = read_bluecherry_config(args.config)
    camera = get_camera(cfg, args.camera)
    cols, rows = grid_size(camera)
    expected = cols * rows
    if len(camera["motion_map"]) != expected:
        raise RuntimeError("Camera map length {} does not match expected {}".format(len(camera["motion_map"]), expected))

    work_dir = Path(args.work_dir).expanduser()
    camera_work = work_dir / "camera-{}".format(camera["id"])
    sample_dir = camera_work / "samples"
    frame_dir = camera_work / "frames"
    output_dir = camera_work / "output"
    output_dir.mkdir(parents=True, exist_ok=True)
    if frame_dir.exists():
        shutil.rmtree(str(frame_dir))

    if args.sample_dir:
        video_files = sorted(Path(args.sample_dir).expanduser().glob("*"))
    else:
        video_files = copy_recent_recordings(camera["id"], sample_dir, args.samples, args.lookback_hours)

    frame_paths = extract_gray_frames(video_files, frame_dir, args.frames_per_video, args.frame_width, args.frame_height)
    keep_zones = parse_zones(args.keep_zone)
    exclude_zones = parse_zones(args.exclude_zone)
    proposed_map, stats = build_map(
        frame_paths,
        cols,
        rows,
        args.frame_width,
        args.frame_height,
        args.sensitivity,
        args.noise_suppression,
        keep_zones,
        exclude_zones,
    )

    stamp = dt.datetime.now().astimezone().strftime("%Y%m%d-%H%M%S-%Z")
    preview_svg = output_dir / "camera-{}-preview-{}.svg".format(camera["id"], stamp)
    report_txt = output_dir / "camera-{}-report-{}.txt".format(camera["id"], stamp)
    report_json = output_dir / "camera-{}-report-{}.json".format(camera["id"], stamp)

    backup_file = None
    if args.apply:
        backup_file = apply_map(cfg, camera, proposed_map, work_dir)

    payload = {
        "generated_at": friendly_now(),
        "camera_id": camera["id"],
        "camera_name": camera["name"],
        "cols": cols,
        "rows": rows,
        "sensitivity": args.sensitivity,
        "noise_suppression": args.noise_suppression,
        "samples": [str(path) for path in video_files],
        "lookback_hours": args.lookback_hours,
        "frame_count": len(frame_paths),
        "current_counts": counts_for_map(camera["motion_map"]),
        "proposed_counts": counts_for_map(proposed_map),
        "current_motion_map": camera["motion_map"],
        "proposed_motion_map": proposed_map,
        "stats": {k: v for k, v in stats.items() if k not in ("scores", "active_counts")},
        "keep_zones": keep_zones,
        "exclude_zones": exclude_zones,
        "applied": bool(args.apply),
        "backup_file": backup_file,
        "preview_svg": str(preview_svg),
        "json_report": str(report_json),
    }

    write_svg(preview_svg, proposed_map, cols, rows, "{} proposed motion map".format(camera["name"]))
    report_json.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n")
    write_report(report_txt, payload)

    if args.stdout_json:
        print(json.dumps(payload, sort_keys=True))
    else:
        print(report_txt)
        print(preview_svg)
        print("Applied: {}".format("yes" if args.apply else "no"))
        print("Proposed counts: {}".format(payload["proposed_counts"]))


def build_parser():
    parser = argparse.ArgumentParser(description="Optimize Bluecherry camera motion maps")
    parser.add_argument("--config", default=CONFIG_PATH)
    sub = parser.add_subparsers(dest="command")
    sub.required = True

    list_p = sub.add_parser("list-cameras", help="List Bluecherry cameras")
    list_p.set_defaults(func=cmd_list)

    analyze = sub.add_parser("analyze", help="Analyze recent recordings and propose a motion map")
    analyze.add_argument("--camera", type=int, required=True)
    analyze.add_argument("--work-dir", default=DEFAULT_WORK_DIR)
    analyze.add_argument("--sample-dir", help="Use existing readable video samples instead of Docker-copying recent recordings")
    analyze.add_argument("--samples", type=int, default=6)
    analyze.add_argument("--lookback-hours", type=int, help="Deep-scan lookback window in hours")
    analyze.add_argument("--frames-per-video", type=int, default=6)
    analyze.add_argument("--frame-width", type=int, default=320)
    analyze.add_argument("--frame-height", type=int, default=240)
    analyze.add_argument("--sensitivity", type=int, default=5, choices=range(1, 11), metavar="1-10")
    analyze.add_argument("--noise-suppression", type=int, default=5, choices=range(0, 11), metavar="0-10")
    analyze.add_argument("--keep-zone", action="append", help="Force an important grid zone on: x1,y1,x2,y2")
    analyze.add_argument("--exclude-zone", action="append", help="Force a grid zone off: x1,y1,x2,y2")
    analyze.add_argument("--apply", action="store_true", help="Save proposed map to Devices.motion_map")
    analyze.add_argument("--stdout-json", action="store_true", help=argparse.SUPPRESS)
    analyze.set_defaults(func=cmd_analyze)

    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        args.func(args)
    except Exception as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
